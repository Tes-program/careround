<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name"/>

    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${appName}"}</customFields>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <message>message</message>
                <logger>logger</logger>
                <thread>thread</thread>
            </fieldNames>
            <!-- Include MDC fields: hospitalId, userId, requestId automatically -->
            <includeMdcKeyName>hospitalId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>requestId</includeMdcKeyName>
        </encoder>
    </appender>

    <!-- Plain text for local dev -->
    <appender name="PLAIN_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="local,dev">
        <root level="INFO">
            <appender-ref ref="PLAIN_STDOUT"/>
        </root>
        <logger name="com.careround" level="DEBUG"/>
    </springProfile>

    <springProfile name="prod,staging">
        <root level="INFO">
            <appender-ref ref="JSON_STDOUT"/>
        </root>
        <logger name="com.careround" level="INFO"/>
    </springProfile>

    <!-- Default (no profile) — use plain for tests -->
    <springProfile name="!local &amp; !dev &amp; !prod &amp; !staging">
        <root level="INFO">
            <appender-ref ref="PLAIN_STDOUT"/>
        </root>
    </springProfile>
</configuration>
