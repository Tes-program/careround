# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=
MYSQL_USER=careround
MYSQL_PASSWORD=

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# ── Mail (use any SMTP — Gmail app password works for demo) ────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://<your-domain>

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=

# ── Domain (used by nginx ssl.conf and Grafana root URL) ───────────────────
DOMAIN=

# ── Image tag (set automatically by CI from git SHA) ───────────────────────
IMAGE_TAG=latest

# ── Local dev only (not used in production docker-compose.prod.yml) ────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
REDIS_HOST=localhost
REDIS_PORT=6379
CAREROUND_APP_ACTIVATION_BASE_URL=http://localhost:3000/activate
CAREROUND_PLATFORM_BOOTSTRAP_ADMIN_EMAIL=platform-admin@careround.local
CAREROUND_PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=<set-only-for-first-startup-then-remove>
